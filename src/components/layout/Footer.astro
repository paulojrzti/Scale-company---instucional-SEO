---
import { services } from '@data/services';
import logoUrl from '../../assets/brand/logo.svg?url';

const year = new Date().getFullYear();

// NAP - TODO: preencher com dados reais (deve ser IDÊNTICO ao GBP)
const nap = {
  address: 'Vila Velha, ES',
  phone:   '(27) XXXX-XXXX',
  email:   'contato@scale.com.br',
};
---

<footer class="border-t border-white/10" style="background-color: #011829;">
  <div class="container py-16">

    <div class="grid grid-cols-1 gap-10 sm:grid-cols-2 lg:grid-cols-4 mb-12">

      <!-- Marca -->
      <div class="lg:col-span-1">
        <a href="/" class="inline-block mb-4" aria-label="Scale">
          <img src={logoUrl} alt="Scale" class="h-7 w-auto" />
        </a>
        <p class="text-sm leading-relaxed max-w-[220px] mb-5" style="color: rgba(255,255,255,0.45);">
          Agência de marketing digital em Vila Velha, ES. Crescimento real para empresas locais.
        </p>
        <address class="not-italic text-sm space-y-1" style="color: rgba(255,255,255,0.45);">
          <div>{nap.address}</div>
          <div>
            <a href={`tel:${nap.phone.replace(/\D/g,'')}`} class="hover:text-brand-primary transition-colors">
              {nap.phone}
            </a>
          </div>
          <div>
            <a href={`mailto:${nap.email}`} class="hover:text-brand-primary transition-colors">
              {nap.email}
            </a>
          </div>
        </address>
      </div>

      <!-- Serviços -->
      <div>
        <p class="text-xs font-semibold uppercase tracking-wider mb-4" style="color: rgba(255,255,255,0.7);">Serviços</p>
        <ul class="space-y-3">
          {services.map((s) => (
            <li>
              <a
                href={`/servicos/${s.slug}`}
                class="text-sm hover:text-brand-primary transition-colors"
                style="color: rgba(255,255,255,0.45);"
              >
                {s.name}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Cidades -->
      <div>
        <p class="text-xs font-semibold uppercase tracking-wider mb-4" style="color: rgba(255,255,255,0.7);">Áreas de atuação</p>
        <ul class="space-y-3">
          {[
            { label: 'Vila Velha, ES', href: '/vila-velha' },
            { label: 'Vitória, ES',    href: '/vitoria' },
            { label: 'Serra, ES',      href: '/serra' },
            { label: 'Espírito Santo', href: '/espirito-santo' },
          ].map((c) => (
            <li>
              <a
                href={c.href}
                class="text-sm hover:text-brand-primary transition-colors"
                style="color: rgba(255,255,255,0.45);"
              >
                {c.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Empresa -->
      <div>
        <p class="text-xs font-semibold uppercase tracking-wider mb-4" style="color: rgba(255,255,255,0.7);">Empresa</p>
        <ul class="space-y-3">
          {[
            { label: 'Sobre nós', href: '/sobre' },
            { label: 'Cases',     href: '/casos' },
            { label: 'Blog',      href: '/blog' },
            { label: 'Contato',   href: '/contato' },
          ].map((l) => (
            <li>
              <a
                href={l.href}
                class="text-sm hover:text-brand-primary transition-colors"
                style="color: rgba(255,255,255,0.45);"
              >
                {l.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

    </div>

    <div class="pt-8 border-t border-white/10 flex items-center justify-between flex-wrap gap-4">
      <p class="text-xs" style="color: rgba(255,255,255,0.25);">&copy; {year} Scale. Todos os direitos reservados.</p>
    </div>

  </div>
</footer>
