---
import { services } from '@data/services';

const year = new Date().getFullYear();

// NAP — TODO: preencher com dados reais (deve ser IDÊNTICO ao GBP)
const nap = {
  address: 'Vila Velha – ES',
  phone:   '(27) XXXX-XXXX',
  email:   'contato@scale.com.br',
};
---

<footer class="bg-surface-subtle border-t border-edge mt-24">
  <div class="container py-16">

    <div class="grid grid-cols-1 gap-10 sm:grid-cols-2 lg:grid-cols-4 mb-12">

      <!-- Marca -->
      <div class="lg:col-span-1">
        <a href="/" class="inline-block mb-4" aria-label="Scale">
          <!-- TODO: logo real -->
          <span class="font-heading text-2xl font-extrabold text-ink">Scale</span>
        </a>
        <p class="text-sm text-ink-light leading-relaxed max-w-[220px] mb-5">
          Agência de marketing digital em Vila Velha – ES. Crescimento real para empresas locais.
        </p>
        <address class="not-italic text-sm text-ink-light space-y-1">
          <div>{nap.address}</div>
          <div><a href={`tel:${nap.phone.replace(/\D/g,'')}`} class="hover:text-brand-primary transition-colors">{nap.phone}</a></div>
          <div><a href={`mailto:${nap.email}`} class="hover:text-brand-primary transition-colors">{nap.email}</a></div>
        </address>
      </div>

      <!-- Serviços -->
      <div>
        <p class="text-xs font-semibold text-ink uppercase tracking-wider mb-4">Serviços</p>
        <ul class="space-y-3">
          {services.map((s) => (
            <li>
              <a href={`/servicos/${s.slug}`} class="text-sm text-ink-light hover:text-brand-primary transition-colors">
                {s.name}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Cidades -->
      <div>
        <p class="text-xs font-semibold text-ink uppercase tracking-wider mb-4">Áreas de atuação</p>
        <ul class="space-y-3">
          {[
            { label: 'Vila Velha – ES', href: '/vila-velha' },
            { label: 'Vitória – ES',    href: '/vitoria' },
            { label: 'Serra – ES',      href: '/serra' },
            { label: 'Espírito Santo',  href: '/espirito-santo' },
          ].map((c) => (
            <li>
              <a href={c.href} class="text-sm text-ink-light hover:text-brand-primary transition-colors">{c.label}</a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Empresa -->
      <div>
        <p class="text-xs font-semibold text-ink uppercase tracking-wider mb-4">Empresa</p>
        <ul class="space-y-3">
          {[
            { label: 'Sobre nós', href: '/sobre' },
            { label: 'Cases',     href: '/casos' },
            { label: 'Blog',      href: '/blog' },
            { label: 'Contato',   href: '/contato' },
          ].map((l) => (
            <li>
              <a href={l.href} class="text-sm text-ink-light hover:text-brand-primary transition-colors">{l.label}</a>
            </li>
          ))}
        </ul>
      </div>

    </div>

    <div class="pt-8 border-t border-edge flex items-center justify-between flex-wrap gap-4">
      <p class="text-xs text-ink-light">&copy; {year} Scale. Todos os direitos reservados.</p>
    </div>

  </div>
</footer>
