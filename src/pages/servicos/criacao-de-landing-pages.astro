---
/**
 * Landing Pages — /servicos/criacao-de-landing-pages
 * Keywords: "criação de landing page", "landing page profissional", "landing page para google ads"
 */
import ServiceLayout from '@layouts/ServiceLayout.astro';
import LocalCTA from '@components/sections/LocalCTA.astro';
import FAQ from '@components/sections/FAQ.astro';
import { getServiceBySlug } from '@data/services';

const service = getServiceBySlug('criacao-de-landing-pages')!;

const faqs = [
  {
    question: 'O que é uma landing page?',
    answer: 'Landing page é uma página de conversão criada para uma campanha específica. Ao contrário do site, ela tem um único objetivo: fazer o visitante tomar uma ação (preencher formulário, ligar, comprar).',
  },
  {
    question: 'Preciso de landing page se já tenho site?',
    answer: 'Sim. Direcionar anúncios para a home do site desperdiça verba. A landing page é otimizada para conversão, com mensagem alinhada ao anúncio. O resultado é um custo por lead muito menor.',
  },
  {
    question: 'Quanto tempo leva para criar uma landing page?',
    answer: 'Entregamos em 7 a 14 dias úteis após aprovação do briefing.',
  },
];
---

<ServiceLayout
  title="Criação de Landing Pages Profissionais | Scale"
  description="Landing pages de alta conversão para campanhas de tráfego pago, lançamentos e captação de leads. Design focado em resultado. Vila Velha e todo o Brasil."
  service={service}
>
  <section class="section bg-surface-subtle">
    <div class="container">
      <h1 class="font-heading text-4xl sm:text-5xl font-extrabold text-ink leading-tight mb-4">
        Landing Pages que convertem visitantes em clientes
      </h1>
      <p class="text-lg text-ink-light leading-relaxed mb-8 max-w-2xl">
        Páginas de alta conversão para campanhas de Google Ads, Meta Ads e lançamentos, com design e copy focados em resultado.
      </p>
      <div class="flex gap-4 flex-wrap">
        <a href="/contato" class="px-8 py-4 text-lg font-semibold rounded-lg bg-brand-primary text-ink-inverse hover:bg-brand-secondary border-2 border-brand-primary transition-colors">
          Solicitar orçamento
        </a>
        <a href="/vila-velha/criacao-de-landing-pages" class="px-8 py-4 text-lg font-semibold rounded-lg border-2 border-brand-primary text-brand-primary hover:bg-brand-primary hover:text-ink-inverse transition-colors">
          Landing page em Vila Velha
        </a>
      </div>
    </div>
  </section>

  <FAQ items={faqs} />
  <LocalCTA city="Vila Velha" service="Landing Pages" />
</ServiceLayout>
