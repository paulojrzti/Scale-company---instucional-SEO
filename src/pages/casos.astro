---
/**
 * Cases — /cases
 * Portfólio de resultados: sites criados, campanhas, resultados de SEO
 */
import BaseLayout from '@layouts/BaseLayout.astro';
---

<BaseLayout
  title="Cases de Sucesso | Scale — Agência de Marketing Digital"
  description="Veja os resultados reais que a Scale entregou para empresas de Vila Velha e Espírito Santo: sites, SEO, tráfego pago e redes sociais."
>
  <section class="section">
    <div class="container">
      <div class="section-header">
        <span class="section-label">Portfólio</span>
        <h1 class="section-title">Cases de Sucesso</h1>
        <p class="section-subtitle">
          Resultados reais para empresas do Espírito Santo.
        </p>
      </div>

      <!-- TODO: adicionar cards de cases após acumular resultados -->
      <p class="text-center text-ink-light py-16">
        Cases em breve — resultados em construção.
      </p>
    </div>
  </section>
</BaseLayout>
