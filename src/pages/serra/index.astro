---
import LocalLayout from '@layouts/LocalLayout.astro';
import { getCityBySlug } from '@data/cities';
const city = getCityBySlug('serra')!;
---
<LocalLayout
  title="Agência de Marketing Digital em Serra – ES | Scale"
  description="Scale: agência de marketing digital em Serra (ES). Criação de sites, SEO e tráfego pago. (27) XXXX-XXXX."
  city={city}
>
  <section class="section bg-surface-subtle">
    <div class="container">
      <span class="inline-flex items-center gap-2 bg-green-50 border border-green-200 text-green-700 px-4 py-1.5 rounded-full text-sm font-semibold mb-6">
        📍 Serra – ES
      </span>
      <h1 class="font-heading text-4xl sm:text-5xl font-extrabold text-ink leading-tight mb-4">
        Agência de Marketing Digital em Serra – ES
      </h1>
      <p class="text-lg text-ink-light leading-relaxed mb-8 max-w-2xl">
        Marketing digital para empresas de Serra — do site ao Google.
      </p>
      <div class="flex gap-4 flex-wrap">
        <a href="/contato" class="px-8 py-4 text-lg font-semibold rounded-lg bg-brand-primary text-ink-inverse hover:bg-brand-secondary border-2 border-brand-primary transition-colors">
          Solicitar orçamento
        </a>
      </div>
    </div>
  </section>
  <section class="section">
    <div class="container">
      <a href="/serra/criacao-de-sites" class="inline-block p-5 rounded-xl border border-edge bg-surface-card hover:border-brand-primary hover:shadow-md transition-all">
        <p class="font-semibold text-ink text-lg">🌐 Criação de Sites em Serra</p>
      </a>
    </div>
  </section>
</LocalLayout>
