<script>
  (() => {
    const outer    = document.getElementById('srv-scroll-outer')!;
    const track    = document.getElementById('srv-track')!;
    const progress = document.getElementById('srv-progress')!;

    function update() {
      const outerRect  = outer.getBoundingClientRect();
      const outerH     = outer.offsetHeight;
      const winH       = window.innerHeight;
      const scrollable = outerH - winH;                    // total scroll dentro da seção
      const scrolled   = Math.max(0, -outerRect.top);      // quanto já rolou
      const pct        = Math.min(1, scrolled / scrollable);

      const trackW     = track.scrollWidth;
      const containerW = outer.offsetWidth;
      const maxX       = -(trackW - containerW); // track vai até o fim do conteúdo
      track.style.transform  = `translateX(${pct * maxX}px)`;
      progress.style.transform = `scaleX(${pct})`;
    }

    window.addEventListener('scroll', update, { passive: true });
    window.addEventListener('resize', update, { passive: true });
    update();
  })();
</script>


