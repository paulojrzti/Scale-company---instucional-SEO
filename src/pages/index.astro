---
/**
 * Home — /
 * Target: "agência de marketing digital", "agência de marketing digital vila velha"
 */
import BaseLayout from '@layouts/BaseLayout.astro';
import GlassEffect from '@components/ui/GlassEffect.astro';
import { services } from '@data/services';
import ScaleTestimonials from '@components/ui/TestimonialStack';
import ScaleTestimonialSlider from '@components/ui/TestimonialSlider';

import logoMahai     from '../assets/logos-parceiros/simple_logo_mahai.png?url';
import logoAtivo1    from '../assets/logos-parceiros/Ativo-1.png?url';
import logoAtivo3    from '../assets/logos-parceiros/Ativo-3-1024x252-1.png?url';
import logoHash      from '../assets/logos-parceiros/50950f7c3c4647103d00017cb4d48bc9-removebg-preview.png?url';
import logoMaskGrp   from '../assets/logos-parceiros/Mask-group.png?url';
import logoMaskGrp1  from '../assets/logos-parceiros/Mask-group-1.png?url';

/**
 * Gradient bars — mesma matemática do componente gradient-bar-hero-section
 */
const barHeights = [100, 88, 76, 65, 55, 45, 37, 30, 37, 45, 55, 65, 76, 88, 100];

const partnerLogos = [
  { src: logoMahai,   alt: 'Mahai'   },
  { src: logoAtivo1,  alt: 'Parceiro' },
  { src: logoAtivo3,  alt: 'Parceiro' },
  { src: logoHash,    alt: 'Parceiro' },
  { src: logoMaskGrp, alt: 'Parceiro' },
  { src: logoMaskGrp1,alt: 'Parceiro' },
];

const faqs = [
  {
    q: 'Já tive experiência ruim com agência. Por que a Scale seria diferente?',
    a: 'Antes de qualquer proposta, fazemos um diagnóstico gratuito e honesto. Se não for o momento certo, dizemos isso. Nossa cultura é transparência total: você acompanha cada decisão e cada resultado em linguagem de negócio.',
  },
  {
    q: 'Quanto preciso investir por mês?',
    a: 'Depende do objetivo e do canal. O orçamento de mídia é definido com base na sua meta de resultado, não em pacote fixo. No diagnóstico gratuito mapeamos o investimento ideal para o seu caso.',
  },
  {
    q: 'Em quanto tempo começo a ver resultado?',
    a: 'Tráfego pago pode gerar leads em 2 a 4 semanas. SEO leva de 3 a 6 meses para resultados consistentes. Site: 20 a 30 dias úteis. Somos transparentes sobre prazos desde o início, sem promessa irreal.',
  },
  {
    q: 'A Scale atende o meu segmento?',
    a: 'Atendemos empresas de diversos segmentos em Vila Velha, Vitória, Serra e todo o ES. No diagnóstico avaliamos o fit e te dizemos com clareza o que podemos entregar.',
  },
  {
    q: 'Posso cancelar quando quiser?',
    a: 'Sim. Contratos mensais, sem fidelidade forçada. Retenção vem de resultado, não de cláusula contratual.',
  },
];
---

<BaseLayout
  title="Agência de Marketing Digital em Vila Velha – ES | Scale"
  description="Scale é a agência de marketing digital em Vila Velha (ES) especializada em criação de sites, tráfego pago, SEO e redes sociais. Resultados reais para empresas locais."
>

<style>
  /* FAQ disclosure marker hide */
  details > summary { list-style: none; }
  details > summary::-webkit-details-marker { display: none; }

  /* Marquee fade edges */
  .marquee-wrap {
    -webkit-mask: linear-gradient(to right, transparent, black 12%, black 88%, transparent);
    mask: linear-gradient(to right, transparent, black 12%, black 88%, transparent);
  }

  /* Gradient bars — hero background (gradient-bar-hero-section style) */
  @keyframes waveMovement {
    0% { transform: scaleY(calc(var(--target-scale) * 0.4)); opacity: 0.3; }
    100% { transform: scaleY(var(--target-scale)); opacity: 0.9; }
  }
  .hero-bar {
    flex: 1 0 calc(100% / 15);
    max-width: calc(100% / 15);
    height: 100%;
    background: linear-gradient(to top, #00BAFF, #1630DF 55%, transparent 100%);
    transform-origin: bottom;
    animation: waveMovement 2s ease-in-out infinite alternate;
  }

  /* Wrapper que controla a visibilidade coletiva via scroll, sem matar as ondas */
  #hero-bars-wrapper {
    width: 100%;
    height: 100%;
    transform-origin: bottom;
    transition: transform 1.4s cubic-bezier(0.16, 1, 0.3, 1);
  }

  /* Gradient text — headline accent */
  .text-gradient-brand {
    background: linear-gradient(90deg, #00BAFF 0%, #6b8fff 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
</style>

<!-- ===================================================
     HERO — gradient-bar-hero-section (Scale identity):
     barras animadas na base, headline centralizada,
     fonte mista Inter regular + Fraunces italic,
     CTA com spinning gradient border
     =================================================== -->
<section
  class="relative flex flex-col items-center justify-center overflow-hidden -mt-16"
  style="min-height: 100svh; background-color: #010f1c;"
>

  <!-- Gradient Bars — exato padrão do componente, cores da marca -->
  <div class="absolute inset-0 z-0 overflow-hidden" aria-hidden="true">
    <div id="hero-bars-wrapper">
      <div class="flex h-full w-full">
        {barHeights.map((h, i) => {
          // Efeito de onda assimétrica vertical (Senoide descompassada + progressão linear)
          const pulseDelay = Math.max(0, (i * 0.15) + Math.sin(i * 1.2) * 0.4).toFixed(2);
          return (
            <div
              class="hero-bar"
              data-h={h}
              style={`--target-scale: ${h / 100}; animation-delay: -${pulseDelay}s;`}
            ></div>
          );
        })}
      </div>
    </div>
    <!-- Fade superior: esconde a borda de cima das barras -->
    <div
      class="absolute inset-0"
      style="background: linear-gradient(to bottom, #010f1c 0%, rgba(1,15,28,0.7) 20%, transparent 45%, rgba(1,15,28,0.65) 75%, #010f1c 100%);"
    ></div>
  </div>

  <!-- Conteúdo centralizado — como no componente original -->
  <div class="relative z-10 text-center w-full max-w-4xl mx-auto px-6 flex flex-col items-center">

    <!-- Badge — liquid glass sutil, borda gradiente estática (não é botão) -->
    <div class="mb-8 hero-animate-1">
      <GlassEffect
        className="inline-flex items-center gap-2 px-5 py-2.5 text-xs font-semibold !cursor-default"
        glassClass="bg-[#010f1c]/75"
        rounded="rounded-full"
      >
        <span style="color: rgba(0,186,255,0.70);">✦</span>
        <span style="color: rgba(255,255,255,0.65);">+240 empresas atendidas no Brasil inteiro</span>
      </GlassEffect>
    </div>

    <!-- Headline principal -->
    <h1 
      class="w-full font-heading font-bold leading-[1.05] tracking-tight mb-4 px-4 mx-auto text-balance hero-animate-2"
      style="font-size: clamp(2.2rem, 5.5vw, 4.5rem); max-width: 1000px; background: linear-gradient(to bottom, #ffffff 30%, #a1a1aa 75%, rgba(176,184,193,0.05) 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent;"
    >
      Crescimento previsível para sua empresa.
    </h1>
    
    <h2
      class="text-xl md:text-2xl font-body font-semibold mb-8 hero-animate-3"
      style="color: #00BAFF;"
    >
      Marketing que de fato converte.
    </h2>

    <!-- Subtítulo — como no componente original -->
    <div class="mb-10 px-4 hero-animate-4">
      <p
        class="text-lg md:text-xl font-body leading-relaxed max-w-2xl mx-auto"
        style="color: rgba(255,255,255,0.60);"
      >
        <strong class="font-semibold" style="color: rgba(255,255,255,0.85);">Tráfego pago, sites, SEO</strong> e <strong class="font-semibold" style="color: rgba(255,255,255,0.85);">redes sociais</strong> para empresas em Vila Velha
        e no ES que querem <strong class="font-semibold" style="color: rgba(255,255,255,0.85);">escalar com previsibilidade</strong>.
      </p>
    </div>

    <!-- CTAs — spinning gradient border (ref1 copy) + link secundário -->
    <div class="flex items-center gap-5 flex-wrap justify-center mb-12 hero-animate-4">

      <!-- Botão com border de conic-gradient girando -->
      <span class="relative inline-block overflow-hidden rounded-full" style="padding: 1.5px;">
        <span
          class="animate-spin-slow absolute pointer-events-none"
          aria-hidden="true"
          style="inset: -100%; background: conic-gradient(from 90deg at 50% 50%, #00BAFF 0%, #1630DF 50%, #00BAFF 100%);"
        ></span>
        <a
          href="/contato"
          class="relative inline-flex items-center gap-2 px-8 py-4 text-base font-semibold rounded-full transition-opacity hover:opacity-90"
          style="background: #010f1c; color: white;"
        >
          Diagnóstico gratuito
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </a>
      </span>

      <!-- Ver serviços — liquid glass pill -->
      <GlassEffect
        href="/servicos"
        className="inline-flex items-center gap-2 px-5 py-3 text-sm font-semibold text-white/80 group-hover:text-white"
        glassClass="bg-white/5 group-hover:bg-white/10"
        rounded="rounded-full"
      >
        Ver serviços
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/>
        </svg>
      </GlassEffect>
    </div>

    <!-- Ícones sociais — liquid glass circles -->
    <div class="flex justify-center gap-3 hero-animate-4">
      <!-- Instagram -->
      <GlassEffect
        href="https://instagram.com"
        className="w-10 h-10 text-white/60 group-hover:text-[#00BAFF]"
        glassClass="bg-white/5 group-hover:bg-[#00BAFF]/15"
        rounded="rounded-full"
        target="_blank"
      >
        <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
          <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
          <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/>
          <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/>
        </svg>
      </GlassEffect>
      <!-- LinkedIn -->
      <GlassEffect
        href="https://linkedin.com"
        className="w-10 h-10 text-white/60 group-hover:text-[#00BAFF]"
        glassClass="bg-white/5 group-hover:bg-[#00BAFF]/15"
        rounded="rounded-full"
        target="_blank"
      >
        <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
          <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/>
          <rect x="2" y="9" width="4" height="12"/>
          <circle cx="4" cy="4" r="2"/>
        </svg>
      </GlassEffect>
      <!-- WhatsApp -->
      <GlassEffect
        href="https://wa.me/5527000000000"
        className="w-10 h-10 text-white/60 group-hover:text-[#00BAFF]"
        glassClass="bg-white/5 group-hover:bg-[#00BAFF]/15"
        rounded="rounded-full"
        target="_blank"
      >
        <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
          <path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/>
        </svg>
      </GlassEffect>
    </div>

  </div>
</section>


<!-- ===================================================
     LOGOS MARQUEE — logos reais de parceiros/clientes
     =================================================== -->
<section
  class="py-10 border-b border-white/5 overflow-hidden"
  style="background-color: #010f1c;"
>
  <p
    class="text-center text-xs uppercase tracking-widest mb-8 reveal-fade"
    style="color: rgba(255,255,255,0.20);"
  >
    +240 empresas atendidas no Brasil inteiro
  </p>
  <div
    class="marquee-wrap overflow-hidden"
    style="
      -webkit-mask: linear-gradient(90deg, transparent 0%, #000 12%, #000 88%, transparent 100%);
      mask: linear-gradient(90deg, transparent 0%, #000 12%, #000 88%, transparent 100%);
    "
  >
    <div class="flex items-center gap-16 w-max animate-marquee">
      {[...partnerLogos, ...partnerLogos, ...partnerLogos, ...partnerLogos, ...partnerLogos, ...partnerLogos].map((logo) => (
        <div class="flex-shrink-0 flex items-center justify-center" style="height: 72px;">
          <img
            src={logo.src}
            alt={logo.alt}
            loading="lazy"
            style="
              max-height: 60px;
              max-width: 180px;
              width: auto;
              object-fit: contain;
              filter: brightness(0) invert(1);
              opacity: 0.45;
            "
          />
        </div>
      ))}
    </div>
  </div>
</section>






<!-- ===================================================
     DOR / PERSONA — pain points em cards glassmorphism
     =================================================== -->
<section class="section relative overflow-hidden" style="background-color: #010f1c;">
  <!-- Neon glow dor persona -->
  <div class="absolute inset-0 pointer-events-none" aria-hidden="true" style="background: radial-gradient(circle at 0% 50%, rgba(0, 186, 255, 0.15) 0%, rgba(22, 48, 223, 0.08) 40%, transparent 60%); z-index: 0;"></div>
  
  <div class="container relative z-10">
    <!-- Layout 2 colunas: título + steps à esquerda, imagem à direita (mesma altura total) -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-10 md:gap-16 mb-14 items-stretch" id="pain-feature">

      <!-- Esquerda: título + steps -->
      <div class="flex flex-col reveal-left">
        <div class="mb-8">
          <span
            class="text-xs font-semibold uppercase tracking-widest block mb-4"
            style="color: #00BAFF;"
          >Você se identifica?</span>
          <h2
            class="font-heading font-bold leading-[1.1] pb-2"
            style="font-size: clamp(3rem, 6vw, 4.5rem); background: linear-gradient(to bottom, #ffffff 30%, #a1a1aa 75%, transparent 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent;"
          >
            Você não está sozinho.
          </h2>
        </div>

        <div class="space-y-10">
          {[
            {
              title: 'Relatório sem resultado',
              content: 'Você investe, recebe gráficos bonitos todo mês e as vendas continuam iguais. Marketing que não vira receita é desperdício.',
            },
            {
              title: 'Falta de transparência',
              content: 'Não sabe o que a agência faz com seu dinheiro. Falta clareza no processo, nas decisões e nos próximos passos.',
            },
            {
              title: 'Clique que não converte',
              content: 'O tráfego pago gera clique, mas ninguém fecha. Você paga caro por lead que não vira cliente.',
            },
          ].map((item, i) => (
            <div
              class="pain-step flex items-start gap-5 cursor-pointer"
              data-pain-step={i}
            >
              <!-- Círculo numerado -->
              <div class="pain-step-circle flex-shrink-0" data-pain-circle={i}>
                <span class="pain-step-num">{i + 1}</span>
                <span class="pain-step-check hidden">✓</span>
              </div>

              <div class="flex-1 pt-0.5">
                <!-- Barra de progresso (só aparece no ativo) -->
                <div class="pain-progress-wrap mb-3 hidden" data-pain-progress={i}>
                  <div class="pain-progress-bar" style="height:2px; border-radius:2px; background: rgba(255,255,255,0.08);">
                    <div class="pain-progress-fill" style="height:100%; width:0%; background: linear-gradient(90deg,#1630DF,#00BAFF); border-radius:2px; transition: width 0.1s linear;"></div>
                  </div>
                </div>
                <h3 class="pain-step-title font-semibold text-lg mb-1">{item.title}</h3>
                <p class="pain-step-desc text-sm leading-relaxed">{item.content}</p>
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- Direita: cenas 3D (uma por pain step) — oculto no mobile -->
      <div
        class="hidden md:relative md:block order-first md:order-last reveal-right"
        style="min-height: 380px; height: 100%;"
      >

        <!-- Scene 0: Relatório sem resultado -->
        <div class="pain-slide absolute inset-0 flex items-center justify-center" data-pain-slide="0"
          style="opacity:1;transform:translateY(0);z-index:1;">
          <div class="ps-glow ps-glow-blue"></div>
          <div class="ps-card" style="animation-delay:0s">
            <div class="ps-pill" style="position:absolute;top:-14px;right:16px;">Relatório enviado ✓</div>
            <p class="ps-label">Performance Q1 · 2024</p>
            <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:8px;margin-bottom:18px;">
              <div class="ps-metric">
                <span class="ps-metric-val">12.4K</span>
                <span class="ps-metric-key">Impressões</span>
              </div>
              <div class="ps-metric">
                <span class="ps-metric-val">847</span>
                <span class="ps-metric-key">Cliques</span>
              </div>
              <div class="ps-metric ps-metric-bad">
                <span class="ps-metric-val ps-val-red">R$&nbsp;0</span>
                <span class="ps-metric-key">Receita</span>
              </div>
            </div>
            <div class="ps-bars">
              <div class="ps-bar" style="--h:55%;--delay:0.05s"></div>
              <div class="ps-bar" style="--h:72%;--delay:0.10s"></div>
              <div class="ps-bar" style="--h:48%;--delay:0.15s"></div>
              <div class="ps-bar" style="--h:80%;--delay:0.20s"></div>
              <div class="ps-bar" style="--h:63%;--delay:0.25s"></div>
              <div class="ps-bar" style="--h:38%;--delay:0.30s"></div>
            </div>
            <p class="ps-caption">Cliques <span style="color:#00BAFF">▲</span>&nbsp;&nbsp;•&nbsp;&nbsp;Receita <span style="color:#ef4444">——</span></p>
          </div>
        </div>

        <!-- Scene 1: Falta de transparência -->
        <div class="pain-slide absolute inset-0 flex items-center justify-center" data-pain-slide="1"
          style="opacity:0;transform:translateY(100%);z-index:0;">
          <div class="ps-glow ps-glow-blue"></div>
          <div class="ps-card" style="animation-delay:0.15s">
            <p class="ps-label">Plano de ação — Março</p>
            <div style="margin-bottom:18px;">
              {['90%','65%','80%','50%','75%','42%'].map((w) => (
                <div class="ps-redact" style={`width:${w}`}></div>
              ))}
            </div>
            <div class="ps-lock-wrap">
              <svg width="30" height="36" viewBox="0 0 30 36" fill="none">
                <rect x="3" y="17" width="24" height="16" rx="4" fill="rgba(0,186,255,0.12)" stroke="#00BAFF" stroke-width="1.5"/>
                <path d="M9 17V12a6 6 0 0 1 12 0v5" stroke="#00BAFF" stroke-width="1.5" fill="none" stroke-linecap="round"/>
                <circle cx="15" cy="25" r="2.5" fill="#00BAFF"/>
                <line x1="15" y1="27.5" x2="15" y2="30.5" stroke="#00BAFF" stroke-width="1.5" stroke-linecap="round"/>
              </svg>
              <span class="ps-lock-label">Acesso restrito</span>
            </div>
            <p class="ps-caption">Próximos passos:&nbsp;<span style="color:rgba(255,255,255,0.2);letter-spacing:0.04em">██████████</span></p>
          </div>
        </div>

        <!-- Scene 2: Clique que não converte -->
        <div class="pain-slide absolute inset-0 flex items-center justify-center" data-pain-slide="2"
          style="opacity:0;transform:translateY(100%);z-index:0;">
          <div class="ps-glow ps-glow-red"></div>
          <div class="ps-card" style="animation-delay:0.3s">
            <div class="ps-pill ps-pill-blue" style="position:absolute;top:-14px;left:16px;">Anúncio ativo</div>
            <p class="ps-label">Campanha em execução</p>
            <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:20px;">
              <div class="ps-metric">
                <span class="ps-metric-val">284</span>
                <span class="ps-metric-key">Cliques pagos</span>
              </div>
              <div class="ps-metric ps-metric-bad">
                <span class="ps-metric-val ps-val-red">0</span>
                <span class="ps-metric-key">Conversões</span>
              </div>
            </div>
            <div class="ps-funnel-wrap">
              <div class="ps-funnel-top"></div>
              <div class="ps-funnel-mid"></div>
              <div class="ps-funnel-bot">
                <span style="font-size:10px;font-weight:600;color:rgba(239,68,68,0.6)">R$&nbsp;0</span>
              </div>
            </div>
            <p class="ps-caption">R$&nbsp;1.850 investidos&nbsp;&nbsp;•&nbsp;&nbsp;<span style="color:#ef4444">0 vendas</span></p>
          </div>
        </div>

      </div>
    </div>

    <style is:global>
      /* Steps — opacidade base e ativa */
      .pain-step { opacity: 0.30; transition: opacity 0.5s ease; }
      .pain-step.is-active { opacity: 1; }

      /* Círculo */
      .pain-step-circle {
        width: 40px; height: 40px; border-radius: 50%;
        display: flex; align-items: center; justify-content: center;
        font-size: 1rem; font-weight: 700;
        border: 2px solid rgba(255,255,255,0.15);
        background: rgba(255,255,255,0.05);
        color: rgba(255,255,255,0.40);
        transition: background 0.4s, border-color 0.4s, color 0.4s;
        flex-shrink: 0;
      }
      .pain-step-circle.is-done {
        background: rgba(0,186,255,0.15);
        border-color: #00BAFF;
        color: #00BAFF;
      }
      .pain-step-circle.is-active {
        background: linear-gradient(135deg, #1630DF, #00BAFF);
        border: none;
        color: #fff;
        transform: scale(1.1);
      }

      /* Textos */
      .pain-step-title { color: rgba(255,255,255,0.45); transition: color 0.4s; }
      .pain-step-desc  { color: rgba(255,255,255,0.25); transition: color 0.4s; }
      .pain-step.is-active .pain-step-title { color: #fff; }
      .pain-step.is-active .pain-step-desc  { color: rgba(255,255,255,0.55); }

      /* Slides de imagem */
      .pain-slide {
        transition: opacity 0.5s ease, transform 0.5s cubic-bezier(0.16,1,0.3,1);
      }
      .pain-slide.is-entering {
        opacity: 1 !important;
        transform: translateY(0) !important;
        z-index: 2 !important;
      }
      .pain-slide.is-leaving {
        opacity: 0 !important;
        transform: translateY(-8%) !important;
        z-index: 1 !important;
      }

      /* ── 3D Scene cards ── */
      .ps-glow {
        position: absolute;
        width: 320px; height: 320px;
        border-radius: 50%;
        filter: blur(80px);
        pointer-events: none;
